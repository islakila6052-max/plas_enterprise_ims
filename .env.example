# ---------------------------------------------------------------------------
# Frontend (browser) variables — Vite inlines these into the client bundle.
# They are NOT available to serverless functions at runtime.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Serverless function variables (api/admin/create-user.js) — set these in the
# Vercel project dashboard: Settings > Environment Variables.
# These must NOT be prefixed with VITE_ (Vercel would otherwise expose them to
# the browser). The service-role key is secret and server-side only.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
